{
	"name": "ticket.pm-packages",
	"private": true,
	"license": "MPL-2.0",
	"packageManager": "bun@1.3.11",
	"repository": {
		"type": "git",
		"url": "https://github.com/ticketpm/ticketpm.git"
	},
	"bugs": {
		"url": "https://github.com/ticketpm/ticketpm/issues"
	},
	"homepage": "https://github.com/ticketpm/ticketpm#readme",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"build": "bun --bun tsc -b tsconfig.build.json",
		"format": "bun --bun biome format --write .",
		"lint": "bun --bun biome check .",
		"release:prepare": "bun scripts/prepare-release.mjs",
		"release:publish:jsr": "bun scripts/publish-jsr.mjs",
		"release:publish:npm": "bun scripts/publish-npm.mjs",
		"test": "bun --bun vitest run",
		"typecheck": "bun --bun tsc -p tsconfig.typecheck.json --pretty false"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@types/node": "^25.5.0",
		"bun-types": "^1.3.11",
		"typescript": "^6.0.2",
		"vitest": "^4.1.2"
	}
}
