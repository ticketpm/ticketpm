{
	"name": "@ticketpm/discordjs",
	"version": "0.0.1",
	"description": "discord.js adapters for ticket.pm transcript exports.",
	"license": "MPL-2.0",
	"type": "module",
	"sideEffects": false,
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist",
		"README.md"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"dependencies": {
		"@ticketpm/core": "workspace:*"
	},
	"peerDependencies": {
		"discord.js": ">=14 <15"
	},
	"devDependencies": {
		"discord.js": "^14.0.0"
	},
	"scripts": {
		"build": "bun --bun tsc -p tsconfig.build.json",
		"test": "bun --bun vitest run"
	}
}
